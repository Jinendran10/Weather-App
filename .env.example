# ──────────────────────────────────────────────────────────────────────────────
# WeatherVault – Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=WeatherVault API
APP_VERSION=1.0.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://weather_user:weather_pass@localhost:5432/weatherdb

# ── OpenWeatherMap (required) ─────────────────────────────────────────────────
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Enables Geocoding API, Maps Embed API, Static Maps API, and Places API.
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── YouTube Data API v3 (optional) ────────────────────────────────────────────
# https://console.cloud.google.com/ → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── CORS allowed origins ──────────────────────────────────────────────────────
# Comma-separated list not supported by this config; edit app/config.py for multi-origin.
# Defaults cover localhost dev servers.
